-- .luacov
-- Configuration for LuaCov code coverage

return {
    statsfile = "bin/luacov.stats.out",
    reportfile = "bin/luacov.report.out",

    -- Include only the modules we want to measure
    include = {
        "src/",
    },

    -- Exclude test files and other parts of the project
    exclude = {
        "src/Infrastructure/",
        "src/Presentation/Locale/",
        "src/Presentation/TooltipController%.lua",
        "src/Presentation/TooltipInterface%.lua",
        "src/Tests/",
        "src/Boot%.lua",
        "src/Environment%.lua",
    },
}
